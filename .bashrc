# some more ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

alias v='vi'
alias ..='cd ..'
alias ...='cd ../..'

alias ali='v ~/workspace/dkdc/.bashrc'
alias update='source ~/workspace/dkdc/.bashrc'
alias dkdc='cd ~/workspace/dkdc'

alias nbclear='jupyter nbconvert --ClearOutputPreprocessor.enabled=True --inplace'

alias python='/opt/python/latest/bin/python3.8'
alias pip='pip3'
